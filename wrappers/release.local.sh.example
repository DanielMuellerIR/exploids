# wrappers/release.local.sh.example — Vorlage für die lokale Signing-/Notary-Konfiguration.
#
# So nutzen:
#   1. Kopieren:  cp wrappers/release.local.sh.example wrappers/release.local.sh
#   2. Eigene Werte eintragen (Team-ID, Developer-ID-Identity, notarytool-Profil).
#   3. wrappers/sign-and-release.sh sourct die Datei automatisch.
#
# Die echte release.local.sh ist per .gitignore vom Repo ausgeschlossen — diese Werte
# sind maschinen-/account-spezifisch und gehören NICHT in ein öffentliches Repo.
# Alternativ können alle drei Werte stattdessen als Environment-Variablen gesetzt werden.

# Apple Developer Team-ID (10 Zeichen).
export APPLE_TEAM_ID="XXXXXXXXXX"

# Vollständiger Name der Developer-ID-Application-Signing-Identity, exakt wie in
# `security find-identity -v -p codesigning` angezeigt.
export CODESIGN_IDENTITY="Developer ID Application: Dein Name (XXXXXXXXXX)"

# Name des notarytool-Keychain-Profils (einmalig je Mac via
# `xcrun notarytool store-credentials <name> ...` angelegt).
export NOTARY_PROFILE="meinNotaryProfil"
